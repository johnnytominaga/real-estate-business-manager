<section id="internal-hero">
  <div class="hero-container" style="background-image: url(<%= randomized_internal_header_image %>); background-position: top;">
  </div>
</section>
<main>
  <section class="header wow fadeInUp" style="padding: 60px 0 60px 0;">
    <div class="container">
      <div class="row">
        <div class="section-header">
          <h3>Conversations</h3>
        </div>
      </div>
    </div>
  </section>
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <div class="panel panel-default">
          <div class="panel-heading">Your Conversations</div>
          <div class="body">
            <div class="container">
              <% @conversations.each do |conversation| %>
              <div class="row">
                <div class="col-md-12">
                  <% other = current_user == conversation.sender ? conversation.recipient : conversation.sender %>
                    <%= link_to conversation_messages_path(conversation) do %>
                      <div class="row conversation">
                        <% if conversation.messages.any? %>
                          <div class="col-md-2">
                            <%= image_tag other.show_avatar('300x300'), class: "img-circle avatar-small" %>
                          </div>
                          <div class="col-md-2">
                            <%= other.fullname %>
                            <%= conversation.messages.last.message_time %>
                          </div>
                          <div class="col-md-8">
                            <%= conversation.messages.last.content %>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>
