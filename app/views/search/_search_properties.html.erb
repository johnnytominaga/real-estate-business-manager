<section id="new-property" style="padding: 60px 0px;">
  <div class="container">
    <div class="row">
      <div class="section-header wow fadeInUp">
        <h3 id="properties_title">Search properties</h3>
      </div>
    </div>
    <div class="row">
      <div class="col-md-12">
        <%= render partial: 'search/search_form_selector' %>
      </div>
    </div>

    <div class="row wow fadeInUp text-right" data-wow-delay="0.2s" id="property_sorting" style="padding: 10px 0 30px 0;">
      <%= render partial: 'search/properties_sort' %>
    </div>

    <div class="row" id="property_listing">
      <%= render partial: 'search/properties_list' %>
    </div>
    <div class="row text-center" id="property_listing_loadmore">
      <%= render partial: 'search/properties_list_loadmore' %>
    </div>

    <!-- <div class="row text-center wow fadeIn" id="property_listing_pagination" data-wow-delay="0.1s">
      < %= render partial: 'search/properties_list_pagination', locals: {properties: @arrProperties} %>
    </div> -->
  </div>

</section>
