<div id="property_carousel" class="row wow fadeInUp" style="margin-bottom:10px;">
  <% if @property.property_photos.attached? %>
    <div class="col-md-12">
      <div class="outer">
        <%= content_tag :div, class: "owl-carousel owl-theme", id: "big" do %>
          <% @property.property_photos.each do |photo| %>
            <% if photo.variable? %>
              <div class="item">
                <% if photo.created_at < Date.parse("2018-12-18") %>
                  <% @photo = photo.variant(resize: '770X578') %>
                <% else %>
                  <% if @request_url.include?('rocklandmalta.com') || @request_url.include?('jr-dev-07') %>
                    <% watermark_path = Rails.root.join('app', 'assets', 'images', 'watermark-rockland.png') %>
                  <% else %>
                    <% watermark_path = Rails.root.join('app', 'assets', 'images', 'watermark.png') %>
                  <% end %>
                  <% @photo = photo.variant(
                    combine_options: {
                      gravity: 'center',
                      resize: '770X578',
                      'auto-orient': true,
                      draw: 'image Over 0,0 0,0 "' + (watermark_path).to_s + '"'
                    }
                  ) %>
                <% end %>
                <%= link_to (image_tag @photo), photo, data: { lightbox: "photo" }, href: url_for(@photo) %>
                <% if user_signed_in? %>
                  <div class="row">
                    <% if !browser.platform.ios? && !browser.platform.android? %>
                      <div class="col-md-2">
                        <p style="font-size:11px; padding: 5px;">
                          <% if !photo.id.nil? %>
                            <%= link_to delete_photo_attachment_property_path(photo.id), method: :delete, data: {confirm: 'Do you really want to delete that photo?'}, remote: true do %>
                              <i class="fas fa-trash"></i> Delete
                            <% end %>
                          <% end %>
                        </p>
                      </div>
                    <% end %>
                    <div class="col-md-10 text-right">
                      <p style="font-size:11px; padding: 5px;">
                        <%= link_to url_for(@photo), disposition: 'attachment', target: '_blank' do %><i class="fas fa-file-download"></i> Download this<% end %>
                         |
                        <%= link_to download_all_photos_property_path do %><i class="far fa-file-archive"></i> Download all<% end %>
                        <% if current_user.role_id == "manager" %>
                           |
                          <%= link_to rails_blob_path(photo, disposition: 'attachment') do %><i class="fas fa-download"></i> Download this without watermark<% end %>
                           |
                          <%= link_to download_all_photos_without_watermark_property_path do %><i class="fas fa-file-archive"></i> Download all without watermark<% end %>
                        <% end %>

                      </p>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>
        <%= content_tag :div, class: "owl-carousel owl-theme", id: "thumbs" do %>
          <% @property.property_photos.each do |photo| %>
            <% if photo.variable? %>
              <%= content_tag :div, class: "item" do %>
              <% @thumb = photo.variant(
                combine_options: {
                  gravity: 'center',
                  'auto-orient': true,
                  resize: '128X96'
                }
              ) %>
                <%= image_tag(@thumb) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% else %>
    <% if user_signed_in? %>
      <%= link_to edit_property_path, "data-toggle": "modal", "data-target": "#update-property-modal", remote: true do %>
        <div class="col-md-12 text-center" style="width:100%; height:70vh; background: url(<%= asset_path 'carousel-no-pictures-add.jpg' %>) no-repeat center; background-size: contain;">
        </div>
      <% end %>
    <% else %>
      <div class="col-md-12 text-center" style="width:100%; height:70vh; background: url(<%= asset_path 'carousel-no-pictures.jpg' %>) no-repeat center; background-size: contain;">
      </div>
    <% end %>
  <% end %>
</div>

<script>
  $(document).ready(function() {
    var bigimage = $("#big");
    var thumbs = $("#thumbs");
    //var totalslides = 10;
    var syncedSecondary = true;

    bigimage
      .owlCarousel({
      items: 1,
      slideSpeed: 2000,
      nav: true,
      autoplay: 7500,
      //autoplay: true, <-- if you want to set default slide time (5000)
      dots: false,
      loop: true,
      responsiveRefreshRate: 200,
      navText: [
        '<i class="fa fa-angle-left fa-2x" aria-hidden="true"></i>',
        '<i class="fa fa-angle-right fa-2x" aria-hidden="true"></i>'
      ]
    })
      .on("changed.owl.carousel", syncPosition);

    thumbs
      .on("initialized.owl.carousel", function() {
      thumbs
        .find(".owl-item")
        .eq(0)
        .addClass("current");
    })
      .owlCarousel({
      items: 5,
      dots: false,
      nav: false,
      navText: [
        '<i class="fa fa-angle-left fa-lg" aria-hidden="true"></i>',
        '<i class="fa fa-angle-right fa-lg" aria-hidden="true"></i>'
      ],
      smartSpeed: 200,
      slideSpeed: 500,
      slideBy: 5,
      responsiveRefreshRate: 100
    })
      .on("changed.owl.carousel", syncPosition2);

    function syncPosition(el) {
      //if loop is set to false, then you have to uncomment the next line
      //var current = el.item.index;

      //to disable loop, comment this block
      var count = el.item.count - 1;
      var current = Math.round(el.item.index - el.item.count / 2 - 0.5);

      if (current < 0) {
        current = count;
      }
      if (current > count) {
        current = 0;
      }
      //to this
      thumbs
        .find(".owl-item")
        .removeClass("current")
        .eq(current)
        .addClass("current");
      var onscreen = thumbs.find(".owl-item.active").length - 1;
      var start = thumbs
      .find(".owl-item.active")
      .first()
      .index();
      var end = thumbs
      .find(".owl-item.active")
      .last()
      .index();

      if (current > end) {
        thumbs.data("owl.carousel").to(current, 100, true);
      }
      if (current < start) {
        thumbs.data("owl.carousel").to(current - onscreen, 100, true);
      }
    }

    function syncPosition2(el) {
      if (syncedSecondary) {
        var number = el.item.index;
        bigimage.data("owl.carousel").to(number, 100, true);
      }
    }

    thumbs.on("click", ".owl-item", function(e) {
      e.preventDefault();
      var number = $(this).index();
      bigimage.data("owl.carousel").to(number, 300, true);
    });
  });

</script>
