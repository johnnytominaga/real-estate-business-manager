<th scope="row" class="wow fadeIn"><i class="far fa-handshake"></i> Sold</th>
<td>
  <%= form_with model: @property, url: editors_editor_update_properties_path(id: @property) do |f| %>
    <div class="col-md-2">
      <div class="form-group">
        <div class="checkbox-inline">
            <%= f.check_box :sold %>
        </div>
      </div>
    </div>
    <div class="col-md-10" style="padding: 0px; display: inline-flex;">
      <%= f.submit 'Cancel', name: 'editor_cancel_update', class: 'btn btn-secondary btn-block editor', id: "btnCancel", style: 'margin: 0 5px;' %>
      <div class="actions">
        <%= button_tag(:name => "editor_update_property", :class => "btn btn-form editor", :id => "btnSubmit" ) do %>
          Save
        <% end %>
      </div>

    </div>
  <% end %>
</td>
<td></td>

<script>
  $('#btnSubmit, #btnCancel').click(function() {
    $("#spinner").fadeIn('slow');
    $("#spinner").click(function(){
      $("#spinner").hide();
    })
  });
</script>
