<%= link_to property_path(@property_ranked), target: "_blank" do %>
  <div class="row">
    <div class="col-md-12">
      <p class="text-center">
        Property ID: <%= @property_ranked.id %>
      </p>
    </div>
  </div>
  <% if !@property_ranked.old_id.blank? && @property_ranked.old_id != 0 %>
    <div class="row">
      <div class="col-md-12">
        <p class="text-center" style="font-size: 10px;">
          Old ID: <%= @property_ranked.old_id %>
        </p>
      </div>
    </div>
  <% end %>
<% end %>
