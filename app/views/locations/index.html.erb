<section id="internal-hero">
  <div class="hero-container" style="background-image: url(<%= randomized_internal_header_image %>); background-position: top;">
  </div>
</section>
<main>
  <section class="header wow fadeInUp" style="padding: 60px 0 60px 0;">
    <div class="container">
      <div class="row">
        <div class="section-header">
          <h3>Locations</h3>
        </div>
      </div>
    </div>
  </section>
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <div class="row text-center">
          <% @areas.each do |area| %>
            <div class="row">
              <div class="col-md-12">
                <h3><%= area.area %></h3>
                <% @locations.where("area_id = ?", area.id).each_with_index do |location, index| %>
                  <div class="col-md-3 wow fadeIn" data-wow-delay="0.<%= index %>s" style="margin: 20px 0;">
                    <div class="panel panel-default">
                      <div class="panel-body">
                        <div class="row">
                          <div class="col-md-12">
                            <h2><%= link_to location.name, location_path(location.slug) %></h2>
                          </div>
                        </div>
                      </div>
                      <div class="panel-footer">
                        <div class="row">
                          <div class="col-md-12">
                            <%= link_to area.area, area_path(area.slug) %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
            <hr/>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</main>
