<div class="section-header wow fadeInUp">
  <h3>Contact Us</h3>
    <p>Find your property in 3 simple steps</p>
</div>

<div class="row">
  <div class="col-md-12" id="contact_form" style="padding-bottom: 30px;">
    <%= render partial: 'leads/contact_form' %>
  </div>
</div>
<% if @isProperty.blank? %> <!-- Hides Google maps in Property details page -->
  <div class="row">
    <hr/>
    <div class="col-md-3 contact-info">
      <div class="row wow fadeInUp" data-wow-delay="0.1s">
        <div class="contact-address">
          <address><i class="ion-ios-location-outline"></i> 37, Gorg Borg Olivier Street<br/>Spinola Bay, St. Julian's</address>
        </div>
      </div>
      <div class="row wow fadeInUp" data-wow-delay="0.2s">
        <div class="contact-phone">
          <p><i class="ion-ios-telephone-outline"></i><a href="tel:+35679555586"> +356 7955-5586</a></p>
        </div>
      </div>
      <div class="row wow fadeInUp" data-wow-delay="0.3s">
        <div class="contact-email">
          <% if @request_url.include?('rocklandmalta.com') || @request_url.include?('jr-dev-07') %>
            <p><i class="ion-ios-email-outline"></i><a href="mailto:info@rocklandmalta.com"> info@rocklandmalta.com</a></p>
          <% else %>
            <p><i class="ion-ios-email-outline"></i><a href="mailto:info@example.com"> info@example.com</a></p>
          <% end %>
        </div>
      </div>
      <div class="row wow fadeInUp" data-wow-delay="0.4s">
        <div class="contact-hours">
          <p><i class="ion-ios-time-outline"></i> Mon - Fri: 9:00am - 7:00pm</p>
        </div>
      </div>
    </div>
    <div class="col-md-9">
      <!-- GOOGLE MAPS -->
      <div class="row wow fadeIn" data-wow-delay="0.5s" style="padding: 5px;">
        <div class="col-md-12">
          <div id="map" style="width: 100%; height: 30vh;"></div>

        </div>
      </div>
    </div>
  </div>
<% end %>



<% if !defined?(@isProperty) %> <!-- Hides Google maps in Property details page -->
  <script>
    // Initialize and add the map
    function initMap() {
      // The location of Uluru
      var uluru = {lat: 35.918048, lng: 14.492469};
      // The map, centered at Uluru
      var map = new google.maps.Map(
          document.getElementById('map'), {zoom: 14, center: uluru});
      // The marker, positioned at Uluru
      var marker = new google.maps.Marker({position: uluru, map: map});
    }

  </script>
  <!--Load the API from the specified URL
  * The async attribute allows the browser to render the page while the API loads
  * The key parameter will contain your own API key (which is not needed for this tutorial)
  * The callback parameter executes the initMap() function
  -->
  <script async defer
    src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAhX1nMcpb_JIUOIsS0UqdLFYll0aQ6lEQ&callback=initMap">
  </script>
<% end %>
