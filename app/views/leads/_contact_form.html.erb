<%= form_with model: @lead, url: leads_path(@lead), method: "post", remote: true do |f| %>
  <div class="row" id="step-1">
    <div class="col-md-12 wow fadeInUp">
      <div class="row">
        <div class="col-md-12">
          <h5>Step 1: Fill in your contact information</h5>
        </div>
      </div>
      <div class="row">
        <div class="col-md-3 input wow fadeInUp" data-wow-delay="0.1s">
          <div class="form-group">
            <%= f.label :name do %>Name *<% end %>
            <%= f.text_field :name, placeholder: "Full name", class: "form-control", id: "lead_name" %>
          </div>
        </div>
        <div class="col-md-3 input wow fadeInUp" data-wow-delay="0.2s">
          <div class="form-group">
            <%= f.label :phone_country_code do %>Phone number country code from<% end %>
            <%= f.country_select :phone_country_code, { include_blank: 'Select a country', priority_countries: ["MT", "IT", "GB"], priority_countries_divider: "~~~~~~"}, {class: "form-control countries", id: 'lead_country_code'} %>
          </div>
        </div>
        <div class="col-md-3 input wow fadeInUp" data-wow-delay="0.3s">
          <div class="form-group">
            <%= f.label :phone do %>Phone (without country code) *<% end %>
            <%= f.telephone_field :phone, placeholder: "Your phone number", class: "form-control", id: "lead_phone", maxlength: "12" %>
          </div>
        </div>
        <div class="col-md-3 input wow fadeInUp" data-wow-delay="0.4s">
          <div class="form-group">
            <%= f.label :email %>
            <%= f.email_field :email, placeholder: "Your email", class: "form-control", maxlength: "50" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row wow fadeIn" id="step-2" style="display:none;">
    <div class="col-md-12">
      <div class="row">
        <div class="col-md-12">
          <h5>Step 2: Select the type of contract</h5>
        </div>
      </div>
      <div class="row">
        <div class="col-md-12 input wow fadeIn" data-wow-delay="0.1s">
          <div class="form-group">
            <%= f.select :contract_type, options_for_select([["Property for rent","Rent"],["Buy a property", "Sales"],["Lease a commercial property", "Commercial lease"],["Buy a commercial property", "Commercial sale"]]),
              {prompt: "Are you looking to rent, buy or lease a property? *"},
              {
              id: "contract_type_select",
              class: "form-control"
              } %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row wow fadeIn" id="step-3" style="display:none;">
    <div class="col-md-12">
      <div class="row">
        <div class="col-md-12">
          <h5>Step 3: Tell us a bit more about you're looking for</h5>
        </div>
      </div>
      <div class="row">
        <div class="col-md-3 input wow fadeIn" data-wow-delay="0.1s">
          <div class="form-group">
            <%= f.text_field :check_in_date, placeholder: "When do you need it from? *", class: "form-control", readonly: true, id: "lead_move_in_date" %>
          </div>
        </div>
        <div class="col-md-3 input wow fadeIn" data-wow-delay="0.2s" id="lead_contract_period" style="display:none;">
          <div class="form-group">
            <%= f.select :contract_period, options_for_select(Lead.contract_periods.map { |key, value| [key.humanize, key] }),
              {prompt: "How long do you need it for?"},
              {class: "form-control" }
            %>
          </div>
        </div>
        <div class="col-md-3 input wow fadeIn" data-wow-delay="0.2s">
          <div class="form-group">
            <ul class="form-group">
              <% @areas.each_with_index do |area, index| %>
                <li>
                  <%= f.fields_for :lead_areas, area.lead_areas.build do |l| %>
                    <%= l.check_box :area_id, {checked: false}, area.id, nil %><%= l.label :area_id do %><%= area.area %><% end %>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
        <div class="col-md-3 input wow fadeIn" data-wow-delay="0.3s">
          <div class="form-group">
            <%= f.select :budget, options_for_select(Lead.budgets.map { |key, value| [key.humanize, key, {"id" => "budget-#{value}"}] }),
              {prompt: "What's your budget? *"},
              {class: "form-control"} %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row wow fadeIn" id="lead_bedrooms" style="display:none;">
    <div class="col-md-12 input" data-wow-delay="0.1s">
      <div class="form-group">
        <%= f.select :bedrooms, options_for_select(Lead.bedrooms.map { |key, value| [key.humanize, key] }),
          {prompt: "How many bedrooms would you like to have?"},
          {class: "form-control"} %>
      </div>
    </div>
  </div>

  <div class="row wow fadeIn" id="submit" style="display:none;">
    <div class="col-md-12 input">
      <div class="form-group">
        <%= f.label :description do %>Additional information<% end %><br/>
        <%= f.text_area :description, placeholder: "Tell more about what you're looking for, if you feel like you need to (e.g. number of people who will be moving in with you, where are you guys from, does the property need to be pet friendly, do you have any other preferences or requirements).", rows: 6 %>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6 col-md-offset-3">
        <div class="actions" style="padding: 20px 15px 0 15px;">
          <%= f.submit "Contact us", class: "btn btn-normal btn-block", id: "btnContact3Steps" %>
        </div>
      </div>
    </div>
  </div>


  <% end %>

<!-- STEP BY STEP FORM -->
<script>
jQuery(document).ready(function( $ ) {

  $('#lead_name').add($("#lead_phone, #lead_country_code")).change(function () {
    // var contractType = $("#contract_type_select").val();
      // alert(contractType);
      if( $("#lead_name").val() || $("#lead_phone").val()){
      $("#step-2").css("display", "block");
    }
  });
  $('#contract_type_select').change(function () {
    var contractType = $("#contract_type_select").val();
      console.log(contractType);
    if( contractType.length ){
      $("#step-3").css("display", "block");
      $("#submit").css("display", "block");
    }
    if(contractType == "Rent"){
      $("#lead_bedrooms").css("display", "block");
      $("#lead_contract_period").css("display", "block");
      $("#budget-1,#budget-2,#budget-3,#budget-4,#budget-5").css("display", "block").prop('disabled', false);
      $("#budget-6,#budget-7,#budget-8,#budget-9,#budget-10,#budget-11,#budget-12,#budget-13,#budget-14,#budget-15,#budget-16").css("display", "none").prop('disabled', true);
    }
    if(contractType == "Sales"){
      $("#lead_bedrooms").css("display", "none");
      $("#lead_contract_period").css("display", "none");
      $("#budget-6,#budget-7,#budget-8,#budget-9, #budget-10").css("display", "block").prop('disabled', false);
      $("#budget-1,#budget-2,#budget-3,#budget-4,#budget-5,#budget-11,#budget-12,#budget-13,#budget-14,#budget-15,#budget-16").css("display", "none").prop('disabled', true);
    }
    if(contractType == "Commercial lease"){
      $("#lead_bedrooms").css("display", "none");
      $("#lead_contract_period").css("display", "none");
      $("#budget-11,#budget-12,#budget-13,#budget-14,#budget-15,#budget-16").css("display", "block").prop('disabled', false);
      $("#budget-1,#budget-2,#budget-3,#budget-4,#budget-5,#budget-6,#budget-7,#budget-8,#budget-9,#budget-10").css("display", "none").prop('disabled', true);
    }
    if(contractType == "Commercial sale"){
      $("#lead_bedrooms").css("display", "none");
      $("#lead_contract_period").css("display", "none");
      $("#budget-6,#budget-7,#budget-8,#budget-9, #budget-10").css("display", "block").prop('disabled', false);
      $("#budget-1,#budget-2,#budget-3,#budget-4,#budget-5,#budget-11,#budget-12,#budget-13,#budget-14,#budget-15,#budget-16").css("display", "none").prop('disabled', true);
    }

  });

  $('#btnContact3Steps').click(function() {
    $("#spinner").fadeIn('slow');
  });

  function phone_number_format(){
    var max_chars = 12;
      $('#lead_phone').keydown( function(e){
          if ($(this).val().length >= max_chars) {
              $(this).val($(this).val().substr(0, max_chars));
          }
      });

      $('#lead_phone').keyup( function(e){
          if ($(this).val().length >= max_chars) {
              $(this).val($(this).val().substr(0, max_chars));
          }
      });
  }


  (function($) {
    $.fn.inputFilter = function (inputFilter) {
      return this.on("input keydown keyup mousedown mouseup select contextmenu drop", function() {
        if (inputFilter(this.value)) {
          this.oldValue = this.value;
          this.oldSelectionStart = this.selectionStart;
          this.oldSelectionEnd = this.selectionEnd;
        } else if (this.hasOwnProperty("oldValue")) {
          this.value = this.oldValue;
          this.setSelectionRange(this.oldSelectionStart, this.oldSelectionEnd);
        }
      });
    };
  }(jQuery));

  $("#lead_phone").inputFilter(function(value) {
    return /^\d*$/.test(value);
  });



})
</script>
