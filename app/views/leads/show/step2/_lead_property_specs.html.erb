<div class="col-md-12">
  <div class="row" style="padding: 0 0 10px 0;">
    <div class="col-md-12 wow fadeInUp" data-wow-delay="0.1s">
      <% if @locations.length > 0 %>
        <b>Locations: </b>
        <%= @locations.map{|l| l.name }.join(', ') %>
      <% else %>
        <b>Areas: </b>
        <% if @areas.length > 0 %>
          <%= @areas.map{|a| a.area }.join(', ') %>
        <% end %>
      <% end %>
    </div>
  </div>
  <div class="row" style="display:flex; align-items: center; justify-content: center; padding: 30px 0;">
    <% if @lead.check_in_date? %>
      <div class="col-md-2 text-center wow zoomInDown" data-wow-delay="0.3s">
        <i class="fas fa-calendar-check"></i> <%= @lead.check_in_date.to_time.strftime("%d/%m/%Y") %>
      </div>
    <% end %>
    <% if @lead.contract_type? %>
      <div class="col-md-2 text-center wow zoomInDown" data-wow-delay="0.4s">
        <i class="fas fa-file-contract"></i> <%= @lead.contract_type %>
      </div>
    <% end %>
    <% if @lead.property_type? %>
      <div class="col-md-2 text-center wow zoomInDown" data-wow-delay="0.5s">
        <i class="fas fa-home"></i> <%= Property.property_types.key(@lead.property_type) %>
      </div>
    <% end %>
    <% if @lead.bedrooms? %>
      <div class="col-md-2 text-center wow zoomInDown" data-wow-delay="0.6s">
        <i class="fas fa-bed"></i> <%= @lead.bedrooms %>
      </div>
    <% end %>
    <% if @lead.budget? %>
      <div class="col-md-2 text-center wow zoomInDown" data-wow-delay="0.7s">
        <i class="fas fa-euro-sign"></i> <%= @lead.budget %>
      </div>
    <% end %>
  </div>
</div>
