<div class="row">
  <%= form_with model: @lead, url: update_field_leads_path(id: @lead), html: {class: 'form_row'}, remote: true, method: :patch do |f| %>
    <div class="col-md-7">
      <%= f.select :user_id, options_for_select(User.where('role_id = ? OR role_id = ?', 1,3).where('is_active = ?', true).where('id != ? OR id != ?',1,2).order('first_name ASC').collect {|u| [u.first_name, u.id]},params[:user_id]), \
                          {:include_blank => ''}, {prompt: "Select agent...", class: "form-control edit-field wow zoomInDown", style: 'width: 100%;padding:0;', "data-wow-delay" => "0.2s" } %>

    </div>
    <div class="col-md-5 wow fadeIn" data-wow-delay="0.1s" style="padding: 0px; display: inline-flex;">
      <div class="actions">
        <%= button_tag(:name => "cancel", :class => "edit-button cancel cancel-icon wow zoomInDown", :id => "btnCancel", "data-wow-delay" => "0.3s" ) do %><% end %>
      </div>
      <div class="actions">
        <%= button_tag(:name => "save", :class => "edit-button save save-icon wow zoomInDown", :id => "btnSubmit", "data-wow-delay" => "0.4s") do %><% end %>
      </div>

    </div>
  <% end %>
</div>

<script>
  $('#btnSubmit, #btnCancel').click(function() {
    $("#spinner").fadeIn('slow');
    $("#spinner").click(function(){
      $("#spinner").hide();
    })
  });
</script>
