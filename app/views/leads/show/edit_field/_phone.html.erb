<th scope="row" class="edit-form wow zoomInDown">Phone</th>
<td>
  <%= form_with model: @lead, url: update_field_leads_path(id: @lead), html: {class: 'form_row'}, remote: true, method: :patch do |f| %>
    <div class="col-md-4" style="padding: 0 5px 0 0;">
      <%= f.country_select :phone_country_code, { include_blank: 'Country code from:', priority_countries: ["MT", "IT", "GB"], priority_countries_divider: "~~~~~~"}, {class: "form-control countries edit-field wow zoomInDown", style: 'padding: 0;', id: 'lead_country_code'} %>
    </div>
    <div class="col-md-4" style="padding: 0 5px 0 0;">
      <%= f.telephone_field :phone, placeholder: "Phone number", class: "form-control edit-field wow zoomInDown", style: 'padding: 0 5px;', "data-wow-delay" => "0.2s", id: "lead_phone", maxlength: "12" %>
    </div>

    <div class="col-md-4 wow fadeIn" data-wow-delay="0.1s" style="padding: 0px; display: inline-flex;">
      <div class="actions">
        <%= button_tag(:name => "cancel", :class => "edit-button cancel cancel-icon wow zoomInDown", :id => "btnCancel", "data-wow-delay" => "0.3s" ) do %><% end %>
      </div>
      <div class="actions">
        <%= button_tag(:name => "save", :class => "edit-button save save-icon wow zoomInDown", :id => "btnSubmit", "data-wow-delay" => "0.4s") do %><% end %>
      </div>

    </div>
  <% end %>
</td>

<script>
  $('#btnSubmit, #btnCancel').click(function() {
    $("#spinner").fadeIn('slow');
    $("#spinner").click(function(){
      $("#spinner").hide();
    })
  });
</script>
