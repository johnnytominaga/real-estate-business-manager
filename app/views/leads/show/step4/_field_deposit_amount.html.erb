<% if !lead_property.deposit_amount.blank? %>
  <%= link_to edit_deposit_info_lead_path(lead_property_id: lead_property.id, property_id: lead_property.property_id, attribute: 'deposit_amount'), remote: true do %><strong>Deposit amount: </strong><%= number_to_currency(lead_property.deposit_amount, unit: "€", precision: 0) %><% end %>
<% else %>
  <%= link_to edit_deposit_info_lead_path(lead_property_id: lead_property.id, property_id: lead_property.property_id, attribute: 'deposit_amount'), remote: true do %><strong>Deposit amount: </strong>Click to add<% end %>
<% end %>
