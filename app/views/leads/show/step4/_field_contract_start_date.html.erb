<% if !lead_property.contract_start_date.blank? %>
  <%= link_to edit_deposit_info_lead_path(lead_property_id: lead_property.id, property_id: lead_property.property_id, attribute: 'contract_start_date'), remote: true do %><strong>Contract start date: </strong><%= lead_property.contract_start_date.to_time.strftime("%d/%m/%Y") %><% end %>
<% else %>
  <%= link_to edit_deposit_info_lead_path(lead_property_id: lead_property.id, property_id: lead_property.property_id, attribute: 'contract_start_date'), remote: true do %><strong>Contract start date: </strong>Click to add<% end %>
<% end %>
