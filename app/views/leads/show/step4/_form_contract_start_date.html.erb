<div class="row" style="margin: 10px 0;">
  <%= form_with model: @lead_property, url: update_deposit_info_lead_path(lead_property_id: @lead_property.id, attribute: @attribute), remote: true, method: :patch do |f| %>
    <div class="col-md-9">
      <%= f.text_field :contract_start_date, readonly: true, id: "contract_start_date_field", placeholder: "Select a date...", class: 'new_lead_phase_field wow lightSpeedIn' %>
    </div>
    <div class="col-md-3 wow fadeIn" data-wow-delay="0.1s" style="padding: 0px; display: inline-flex; justify-content: center;">
      <div class="actions">
        <%= button_tag(:name => "cancel", :class => "edit-button cancel cancel-icon wow zoomInDown", :id => "btnCancel", "data-wow-delay": "0.2s" ) do %><% end %>
      </div>
      <div class="actions">
        <%= button_tag(:name => "save", :class => "edit-button save save-icon wow zoomInDown", :id => "btnSubmit", "data-wow-delay": "0.3s") do %><% end %>
      </div>
    </div>
  <% end %>
</div>

<script>
  $('#btnSubmit, #btnCancel').click(function() {
    $("#spinner").fadeIn('slow');
    $("#spinner").click(function(){
      $("#spinner").hide();
    })
  });

  var dateToday = new Date();
  $('#contract_start_date_field').datepicker({
    defaultDate: "+1d",
    numberOfYears: 3,
    changeMonth: true,
    changeYear: true,
    dateFormat: 'dd-M-yy',
    minDate: dateToday
  });

</script>
