<div class="row" style="margin: 10px 0;">
  <%= form_with model: @lead_property, url: proposal_amount_lead_path(lead_property_id: @lead_property.id), remote: true, method: :patch do |f| %>
    <div class="col-md-9">
      <%= f.number_field :proposal_amount, placeholder: "Enter amount...", class: 'new_lead_phase_field wow lightSpeedIn' %>
    </div>
    <div class="col-md-3 wow fadeIn" data-wow-delay="0.1s" style="padding: 0px; display: inline-flex; justify-content: center;">
      <div class="actions">
        <%= button_tag(:name => "cancel", :class => "edit-button cancel cancel-icon wow zoomInDown", :id => "btnCancel", "data-wow-delay": "0.2s" ) do %><% end %>
      </div>
      <div class="actions">
        <%= button_tag(:name => "save", :class => "edit-button save save-icon wow zoomInDown", :id => "btnSubmit", "data-wow-delay": "0.3s") do %><% end %>
      </div>
    </div>
  <% end %>
</div>

<script>
  $('#btnSubmit, #btnCancel').click(function() {
    $("#spinner").fadeIn('slow');
    $("#spinner").click(function(){
      $("#spinner").hide();
    })
  });
</script>
