<div class="modal-header">
  <div class="row modal-header-editor">
    <div class="row">
      <div class="col-md-6">
        <strong>Add new lead: </strong>
      </div>
      <div class="col-md-6">
        <!-- < %= link_to "Go to property page »", property_path(@property.id), target: "_blank;", class:"other_property_link" %> -->
        <button type="button" class="close"  data-dismiss="modal" aria-label="Close" id="btnClose">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
    </div>
  </div>
</div>
<div class="modal-body">

  <%= form_with model: @lead, url: create_from_agent_leads_path, local: true do |f| %>
    <div class="row">
      <div class="col-md-4 input">
        <div class="form-group">
          <%= f.label :name do %>Name *<% end %>
          <%= f.text_field :name, placeholder: "Full name", class: "form-control", id: "lead_name" %>
        </div>
      </div>
      <div class="col-md-4 input">
        <div class="form-group">
          <%= f.label :phone_country_code do %>Phone number country code from<% end %>
          <%= f.country_select :phone_country_code, { include_blank: 'Select a country', priority_countries: ["MT", "IT", "GB"], priority_countries_divider: "~~~~~~"}, {class: "form-control countries", id: 'lead_country_code'} %>
        </div>
      </div>
      <div class="col-md-4 input">
        <div class="form-group">
          <%= f.label :phone do %>Phone * (with prefix, if applicable)<% end %>
          <%= f.telephone_field :phone, placeholder: "Phone number", class: "form-control", id: "lead_phone", maxlength: "12" %>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-4 input">
        <div class="form-group">
          <%= f.label :email %>
          <%= f.email_field :email, placeholder: "Email", class: "form-control", maxlength: "50" %>
        </div>
      </div>

      <div class="col-md-4 input">
        <div class="form-group">
          <%= f.label :contract_type %>
          <%= f.select :contract_type, options_for_select(Lead.contract_types.map { |key, value| [key.humanize, key] }),
            {prompt: "Contract type *"},
            {
            id: "contract_type_select",
            class: "form-control"
            } %>
        </div>
      </div>
      <div class="col-md-4 input">
        <div class="form-group">
          <%= f.label :check_in_date %>
          <%= f.text_field :check_in_date, placeholder: "Check in date *", class: "form-control", readonly: true, id: "lead_check_in_date" %>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-4 input">
        <div class="form-group">
          <%= f.label :bedrooms %>
          <%= f.select :bedrooms, options_for_select(Lead.bedrooms.map { |key, value| [key.humanize, key] }),
            {prompt: "No. of bedrooms"},
            {class: "form-control"} %>
        </div>
      </div>
      <div class="col-md-4 input">
        <div class="form-group">
          <%= f.label :budget %>
          <%= f.select :budget, options_for_select(Lead.budgets.map { |key, value| [key.humanize, key, {"id" => "budget-#{value}"}] }),
            {prompt: "Budget *"},
            {class: "form-control"} %>
        </div>
      </div>
      <div class="col-md-4 input">
        <div class="form-group">
          <ul class="form-group">
            <% @areas.each_with_index do |area, index| %>
              <li>
                <%= f.fields_for :lead_areas, area.lead_areas.build do |l| %>
                  <%= l.check_box :area_id, {checked: false}, area.id, nil %><%= l.label :area_id do %><%= area.area %><% end %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6 col-md-offset-3">
        <div class="actions" style="padding: 20px 15px 0 15px;">
          <%= f.submit "Save", class: "btn btn-normal btn-block", id: "btnNewLead" %>
        </div>
      </div>
    </div>
  <% end %>

</div>

<script>
  jQuery(document).ready(function( $ ) {
    $('#btnNewLead').click(function() {
      $("#spinner").fadeIn('slow');
      $("#spinner").click(function(){
        $("#spinner").hide();
      })
    });

    function phone_number_format(){
      var max_chars = 12;
        $('#lead_phone').keydown( function(e){
            if ($(this).val().length >= max_chars) {
                $(this).val($(this).val().substr(0, max_chars));
            }
        });

        $('#lead_phone').keyup( function(e){
            if ($(this).val().length >= max_chars) {
                $(this).val($(this).val().substr(0, max_chars));
            }
        });
    }


    (function($) {
      $.fn.inputFilter = function (inputFilter) {
        return this.on("input keydown keyup mousedown mouseup select contextmenu drop", function() {
          if (inputFilter(this.value)) {
            this.oldValue = this.value;
            this.oldSelectionStart = this.selectionStart;
            this.oldSelectionEnd = this.selectionEnd;
          } else if (this.hasOwnProperty("oldValue")) {
            this.value = this.oldValue;
            this.setSelectionRange(this.oldSelectionStart, this.oldSelectionEnd);
          }
        });
      };
    }(jQuery));

    $("#lead_phone").inputFilter(function(value) {
      return /^\d*$/.test(value);
    });

    var dateToday = new Date();
    $('#lead_check_in_date').datepicker({
      defaultDate: "+1d",
      numberOfYears: 3,
      changeMonth: true,
      changeYear: true,
      dateFormat: 'dd-M-yy',
      minDate: dateToday
    });

  })
</script>
