<% if @arrProperties.next_page %>
  <div class="col-md-2 col-md-offset-5 wow fadeIn" data-wow-delay="0.1s">
    <div id="load-more">
      <%= link_to "Load more", users_loadmore_path(page: @arrProperties.next_page, q: @q, source: "users", nickname: params[:nickname] ), id: "next_page", class: "btn btn-normal", style: "margin: 10px;", remote: true %>
    </div>
  </div>
<% end %>
<script>
  $('#next_page').click(function() {
    $("#spinner").fadeIn('slow');
  });
</script>
