<section id="devise">
  <div class="hero-container" style="background-image: url(<%= asset_path "hero-bg.jpg" %>); background-position: bottom center;">
    <div class="row">
      <div class="col-md-6 col-md-offset-6" style="padding-top: 12rem;">
        <div class="panel panel-default wow fadeInUp">
          <div class="panel-heading">
            <div class="section-header">
              <h3>Change your password</h3>
            </div>
          </div>
          <div class="panel-body">
            <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
                <%= render 'shared/devisemes' %>
                <%= f.hidden_field :reset_password_token %>

              <div class="form-group">
                <%= f.password_field :password, autocomplete: "off", placeholder: "New Password", class: "form-control" %>
              </div>

              <div class="form-group">
                <%= f.password_field :password_confirmation, autocomplete: "off", placeholder: "Confirm New Password", class: "form-control" %>
              </div>

              <div class="actions">
                <%= f.submit "Change my password", class: "btn btn-primary" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
