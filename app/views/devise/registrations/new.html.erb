<section id="devise">
  <div class="hero-container" style="background-image: url(<%= asset_path "hero-bg.jpg" %>); background-position: bottom center;">
    <div class="row">
      <div class="col-md-6 col-md-offset-6" style="padding-top: 12rem;">
        <div class="panel panel-default wow fadeInUp">
          <div class="panel-heading">
            <div class="section-header">
              <h3>Sign up</h3>
            </div>
          </div>
            <div class="panel-body">
              <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
                <%= render 'shared/devisemes' %>
                  <div class="form-group">
                    <%= f.text_field :nickname, autofocus: true, placeholder: "Nickname", class: "form-control" %>
                  </div>

                  <div class="form-group">
                    <%= f.text_field :first_name, autofocus: true, placeholder: "First name", class: "form-control" %>
                  </div>

                  <div class="form-group">
                    <%= f.text_field :last_name, autofocus: true, placeholder: "Last name", class: "form-control" %>
                  </div>

                <div class="form-group">
                  <%= f.email_field :email, autofocus: true, placeholder: "Email", class: "form-control" %>
                </div>

                <!-- <div class="form-group">
                  < % for role in Role.all %>
                    < %= check_box_tag "user[role_id][#{role.id}]", role, @user.role_id.include?(role.id), {:name => "user[roles][]"}%>
                    < %= label_tag "user_roles_#{role}", role.humanize %><br />
                  < % end %>
                  < %= hidden_field_tag "user[roles][]", "" %>
                </div> -->

                <div class="form-group">
                  <%= f.password_field :password, autocomplete: "off", placeholder: "Password", class: "form-control" %>
                </div>

                <div class="actions">
                  <%= f.submit "Sign up", class: "btn btn-normal btn-block text-center" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
