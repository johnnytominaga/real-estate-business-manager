/* ---------------------------------------------------- */
/* ---------------------------------------------------- */
/*                   Dependencies                       */
/* ---------------------------------------------------- */
/* ---------------------------------------------------- */

*           { margin: 0; }
html, body  { height: 100%; }
html        {
	height:          100%;
  color:           #fff;
	background:      #121212;
	background-size: 100% 100%;
  box-sizing:      border-box;
}
body        {
  position:        relative;
  font-family: "Quicksand", "Helvetica Neue", "Helvetica", "Arial", sans-serif;
	font-size:       12px;
  box-sizing:      border-box;
  overflow-x:      hidden;
}
a {
  color: #fff;
  transition: 0.5s;
	text-decoration: none;
}

a:hover, a:active, a:focus {
  color: #01dc94;
  outline: none;
  text-decoration: none;
}
